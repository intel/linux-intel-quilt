From 185b29774e6ac011fbf1db5e2dd3785545bc2496 Mon Sep 17 00:00:00 2001
From: Li Yifan <yifan2.li@intel.com>
Date: Wed, 4 Mar 2026 11:43:10 +0800
Subject: [PATCH 11/11] [CONFLICT] Resolve pmt_telem_find_and_register_endpoint
 conflict

There is pmt_telem_find_and_register_endpoint conflict when apply
both vsec patch series and pmc enablement patch series. Solve it
in pmc/core.c

Signed-off-by: Li Yifan <yifan2.li@intel.com>
---
 drivers/platform/x86/intel/pmc/core.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/platform/x86/intel/pmc/core.c b/drivers/platform/x86/intel/pmc/core.c
index 55bdc491e9a3..79361bbc60ca 100644
--- a/drivers/platform/x86/intel/pmc/core.c
+++ b/drivers/platform/x86/intel/pmc/core.c
@@ -1391,7 +1391,7 @@ void pmc_core_punit_pmt_init(struct pmc_dev *pmcdev, struct pmc_dev_info *pmc_de
 	}
 
 	if (pmc_dev_info->pc_guid) {
-		ep = pmt_telem_find_and_register_endpoint(pcidev, pmc_dev_info->pc_guid, 0);
+		ep = pmt_telem_find_and_register_endpoint(&pcidev->dev, pmc_dev_info->pc_guid, 0);
 		if (IS_ERR(ep)) {
 			dev_err(&pmcdev->pdev->dev,
 				"pmc_core: couldn't get Package C-state telem endpoint %ld",
-- 
2.43.0

