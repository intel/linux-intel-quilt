From ec99d9088d3bbd6e018692a782607f1b3626494a Mon Sep 17 00:00:00 2001
From: "Shahidan, Muhammad Shahmil" <muhammad.shahmil.shahidan@intel.com>
Date: Wed, 8 Apr 2026 10:27:26 +0800
Subject: [PATCH 03/52] Add IPU6 PSYS drivers

Adding IPU6 PSYS drivers from ipu6-drivers repo to 6.18 kernel.

Signed-off-by: Shahidan, Muhammad Shahmil <muhammad.shahmil.shahidan@intel.com>
---
 drivers/media/pci/intel/ipu6/psys/Makefile    |   27 +
 .../media/pci/intel/ipu6/psys/ipu-fw-psys.c   |  630 ++++
 .../media/pci/intel/ipu6/psys/ipu-fw-psys.h   |  382 +++
 .../pci/intel/ipu6/psys/ipu-fw-resources.c    |  103 +
 .../pci/intel/ipu6/psys/ipu-platform-psys.h   |   78 +
 .../intel/ipu6/psys/ipu-platform-resources.h  |  103 +
 .../pci/intel/ipu6/psys/ipu-psys-compat32.c   |  222 ++
 drivers/media/pci/intel/ipu6/psys/ipu-psys.c  | 2751 +++++++++++++++++
 drivers/media/pci/intel/ipu6/psys/ipu-psys.h  |  354 +++
 .../media/pci/intel/ipu6/psys/ipu-resources.c |  904 ++++++
 .../pci/intel/ipu6/psys/ipu6-fw-resources.c   |  678 ++++
 .../pci/intel/ipu6/psys/ipu6-l-scheduler.c    |  712 +++++
 .../intel/ipu6/psys/ipu6-platform-resources.h |  194 ++
 drivers/media/pci/intel/ipu6/psys/ipu6-ppg.c  |  930 ++++++
 drivers/media/pci/intel/ipu6/psys/ipu6-ppg.h  |   38 +
 .../media/pci/intel/ipu6/psys/ipu6-psys-gpc.c |  209 ++
 drivers/media/pci/intel/ipu6/psys/ipu6-psys.c | 1340 ++++++++
 .../pci/intel/ipu6/psys/ipu6ep-fw-resources.c |  393 +++
 .../ipu6/psys/ipu6ep-platform-resources.h     |   42 +
 .../pci/intel/ipu6/psys/ipu6se-fw-resources.c |  214 ++
 .../ipu6/psys/ipu6se-platform-resources.h     |  103 +
 21 files changed, 10407 insertions(+)
